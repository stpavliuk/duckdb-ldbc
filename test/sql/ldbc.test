# name: test/sql/ldbc.test
# description: test ldbc extension
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT * FROM snb_queries();
----
Catalog Error: Table Function with name snb_queries does not exist!

# Require statement will ensure this test is run with this extension loaded
require ldbc

query I
SELECT success FROM snb_datagen(overwrite = true, download = false, data_path = 'test/data/SNB0.003-mini');
----
true

query I
SELECT COUNT(*) FROM Person;
----
1

query I
SELECT COUNT(*) FROM Message;
----
1

statement error
SELECT success FROM snb_datagen(overwrite = false, download = false, data_path = 'test/data/SNB0.003-mini');
----
Catalog Error: Table with name "Person_workAt_Organisation" already exists!

statement error
SELECT success FROM snb_datagen(sf = 0.1, overwrite = true, download = false, data_path = 'test/data/SNB0.003-mini');
----
Not implemented Error: download=false currently supports only sf=0.003

query I
SELECT COUNT(*) FROM snb_queries();
----
11

query I
SELECT COUNT(*) FROM snb_queries() WHERE category = 'IC' AND query_nr = 7 AND LENGTH(query_pgq) > 0;
----
1

query I
SELECT COUNT(*) FROM snb_answers();
----
0

statement error
PRAGMA snb(10);
----
Invalid Input Error: Unsupported SNB query 10. Available query numbers are listed by snb_queries()

statement error
PRAGMA snb(0);
----
Invalid Input Error: SNB query number must be positive
